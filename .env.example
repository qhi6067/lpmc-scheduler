ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SESSION_SECRET=replace-with-a-long-random-secret

# Set one database URL. DATABASE_URL is preferred, but POSTGRES_URL also works.
DATABASE_URL=
# POSTGRES_URL=

# Required for Excel uploads on Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# Optional override for the built-in emergency password reset login.
# Defaults are system / manager if left blank.
SYSTEM_USERNAME=
SYSTEM_PASSWORD=
