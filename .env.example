ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SESSION_SECRET=replace-with-a-long-random-secret

# Optional for local development. If omitted, the app falls back to server/data/state.json.
# Set one database URL for durable Postgres-backed storage. DATABASE_URL is preferred, but POSTGRES_URL also works.
DATABASE_URL=
# POSTGRES_URL=

# Optional for local development. If omitted, uploaded Excel files are stored in server/data/uploads.
# Required for Vercel Blob-backed uploads.
BLOB_READ_WRITE_TOKEN=

# Optional override for the built-in emergency password reset login.
# Defaults are system / manager if left blank.
SYSTEM_USERNAME=
SYSTEM_PASSWORD=
